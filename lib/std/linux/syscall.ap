#-
  std/linux/syscall — direct Linux system calls, no libc.

  Linux/x86-64 only. The kernel's syscall ABI is a stable, supported
  interface (numbers never change), which is what makes this reasonable
  rather than a stunt — the same is not true of Windows or macOS, whose
  service numbers move between builds.

  Outside Linux/x86-64 this module is deliberately empty: syscall numbers are
  per-arch, so importing it elsewhere fails at the call site rather than
  compiling something that would dial the wrong kernel entry.

  Errors: a syscall returns -errno in the range [-4095, -1] rather than
  setting a global. Use `failed` / `errno_of` on the raw return.
-#
$module std/linux/syscall

$ifdef OS_LINUX
$ifdef ARCH_X86_64

# ── Raw entry points ────────────────────────────────────────────────────
#
# Number in rax, args in rdi/rsi/rdx/r10/r8/r9, result in rax.
#
# The 4th argument is in **r10, not rcx** — the `syscall` instruction itself
# overwrites rcx with the return address (and r11 with rflags), which is why
# the kernel ABI diverges from the C one here and why both are clobbered.
#
# `memory` is not optional: the kernel reads and writes through the pointers
# handed to it, and without it the optimizer may cache a load across the call.

asm fn syscall0(i64 nr: rax) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

asm fn syscall1(i64 nr: rax, i64 a1: rdi) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

asm fn syscall2(i64 nr: rax, i64 a1: rdi, i64 a2: rsi) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

asm fn syscall3(i64 nr: rax, i64 a1: rdi, i64 a2: rsi, i64 a3: rdx) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

asm fn syscall4(i64 nr: rax, i64 a1: rdi, i64 a2: rsi, i64 a3: rdx, i64 a4: r10) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

# A newline terminates a statement, so these signatures cannot wrap.
asm fn syscall5(i64 nr: rax, i64 a1: rdi, i64 a2: rsi, i64 a3: rdx, i64 a4: r10, i64 a5: r8) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

asm fn syscall6(i64 nr: rax, i64 a1: rdi, i64 a2: rsi, i64 a3: rdx, i64 a4: r10, i64 a5: r8, i64 a6: r9) -> i64: rax
    clobbers(rcx, r11, memory)
{
    "syscall"
}

# ── Numbers (x86-64) ────────────────────────────────────────────────────
#
# The complete table, generated from the kernel's own <asm/unistd_64.h>.
# Every Linux syscall is reachable: those without a typed wrapper below are
# called through the raw entry points, by anything that imports this module.
#
#     $import std/linux/syscall
#     syscall2(SYS_STATX, path as i64, buf as i64)
#
# Numbers are per-arch and never change once assigned, which is what makes
# hardcoding them correct rather than fragile. Unused ones cost nothing: a
# const is internal, so `globaldce` collects every one a program never names.

