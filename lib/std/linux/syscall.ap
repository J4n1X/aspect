# ── Flags ───────────────────────────────────────────────────────────────

const i32 STDIN                  = 0
const i32 STDOUT                 = 1
const i32 STDERR                 = 2

const i64 O_RDONLY               = 0
const i64 O_WRONLY               = 1
const i64 O_RDWR                 = 2
const i64 O_CREAT                = 64
const i64 O_TRUNC                = 512
const i64 O_APPEND               = 1024

const i64 SEEK_SET               = 0
const i64 SEEK_CUR               = 1
const i64 SEEK_END               = 2

const i64 PROT_NONE              = 0
const i64 PROT_READ              = 1
const i64 PROT_WRITE             = 2
const i64 PROT_EXEC              = 4

const i64 MAP_SHARED             = 1
const i64 MAP_PRIVATE            = 2
const i64 MAP_FIXED              = 16
const i64 MAP_ANONYMOUS          = 32

# Passed where `openat` wants a dirfd, to resolve a path against the cwd.
const i32 AT_FDCWD               = -100

# ── Error decoding ──────────────────────────────────────────────────────

# The kernel signals failure by returning -errno. Only [-4095, -1] is an
# error: a syscall may legitimately return a large negative value (`lseek`
# past 2^63, say), so the range test is not the same as `ret < 0`.
fn failed(i64 ret) -> bool {
    return ret < 0 && ret > 0 - 4096
}

# The errno of a failed return, or 0 if it did not fail.
fn errno_of(i64 ret) -> i64 {
    if failed(ret) { return 0 - ret }
    return 0
}

# ── Typed wrappers ──────────────────────────────────────────────────────
#
# Each returns the raw kernel result: bytes moved / fd / address on success,
# -errno on failure. Check with `failed`.

fn sys_read(i32 fd, u8 *buf, u64 count) -> i64 {
    return syscall3(SYS_READ, fd, buf as i64, count as i64)
}

fn sys_write(i32 fd, u8 *buf, u64 count) -> i64 {
    return syscall3(SYS_WRITE, fd, buf as i64, count as i64)
}

fn sys_open(u8 *path, i64 flags, i64 mode) -> i64 {
    return syscall3(SYS_OPEN, path as i64, flags, mode)
}

fn sys_openat(i32 dirfd, u8 *path, i64 flags, i64 mode) -> i64 {
    return syscall4(SYS_OPENAT, dirfd, path as i64, flags, mode)
}

fn sys_close(i32 fd) -> i64 {
    return syscall1(SYS_CLOSE, fd)
}

fn sys_lseek(i32 fd, i64 offset, i64 whence) -> i64 {
    return syscall3(SYS_LSEEK, fd, offset, whence)
}

fn sys_mmap(u0 *addr, u64 length, i64 prot, i64 flags, i32 fd, i64 offset) -> i64 {
    return syscall6(SYS_MMAP, addr as i64, length as i64, prot, flags, fd, offset)
}

fn sys_mprotect(u0 *addr, u64 length, i64 prot) -> i64 {
    return syscall3(SYS_MPROTECT, addr as i64, length as i64, prot)
}

fn sys_munmap(u0 *addr, u64 length) -> i64 {
    return syscall2(SYS_MUNMAP, addr as i64, length as i64)
}

fn sys_pread64(i32 fd, u8 *buf, u64 count, i64 offset) -> i64 {
    return syscall4(SYS_PREAD64, fd, buf as i64, count as i64, offset)
}

fn sys_pwrite64(i32 fd, u8 *buf, u64 count, i64 offset) -> i64 {
    return syscall4(SYS_PWRITE64, fd, buf as i64, count as i64, offset)
}

fn sys_dup(i32 fd) -> i64 {
    return syscall1(SYS_DUP, fd)
}

fn sys_dup2(i32 oldfd, i32 newfd) -> i64 {
    return syscall2(SYS_DUP2, oldfd, newfd)
}

fn sys_ftruncate(i32 fd, i64 length) -> i64 {
    return syscall2(SYS_FTRUNCATE, fd, length)
}

fn sys_fsync(i32 fd) -> i64 {
    return syscall1(SYS_FSYNC, fd)
}

fn sys_unlink(u8 *path) -> i64 {
    return syscall1(SYS_UNLINK, path as i64)
}

fn sys_rename(u8 *oldpath, u8 *newpath) -> i64 {
    return syscall2(SYS_RENAME, oldpath as i64, newpath as i64)
}

fn sys_mkdir(u8 *path, i64 mode) -> i64 {
    return syscall2(SYS_MKDIR, path as i64, mode)
}

fn sys_rmdir(u8 *path) -> i64 {
    return syscall1(SYS_RMDIR, path as i64)
}

fn sys_chdir(u8 *path) -> i64 {
    return syscall1(SYS_CHDIR, path as i64)
}

fn sys_getcwd(u8 *buf, u64 size) -> i64 {
    return syscall2(SYS_GETCWD, buf as i64, size as i64)
}

fn sys_readlink(u8 *path, u8 *buf, u64 size) -> i64 {
    return syscall3(SYS_READLINK, path as i64, buf as i64, size as i64)
}

fn sys_access(u8 *path, i64 mode) -> i64 {
    return syscall2(SYS_ACCESS, path as i64, mode)
}

fn sys_brk(u0 *addr) -> i64 {
    return syscall1(SYS_BRK, addr as i64)
}

fn sys_madvise(u0 *addr, u64 length, i64 advice) -> i64 {
    return syscall3(SYS_MADVISE, addr as i64, length as i64, advice)
}

fn sys_getpid() -> i64 {
    return syscall0(SYS_GETPID)
}

fn sys_getppid() -> i64 {
    return syscall0(SYS_GETPPID)
}

fn sys_getuid() -> i64 {
    return syscall0(SYS_GETUID)
}

fn sys_geteuid() -> i64 {
    return syscall0(SYS_GETEUID)
}

fn sys_getgid() -> i64 {
    return syscall0(SYS_GETGID)
}

fn sys_gettid() -> i64 {
    return syscall0(SYS_GETTID)
}

fn sys_getrandom(u8 *buf, u64 count, i64 flags) -> i64 {
    return syscall3(SYS_GETRANDOM, buf as i64, count as i64, flags)
}

fn sys_sched_yield() -> i64 {
    return syscall0(SYS_SCHED_YIELD)
}

fn sys_kill(i32 pid, i32 sig) -> i64 {
    return syscall2(SYS_KILL, pid, sig)
}

# Terminates every thread. Never returns — do NOT call this from a program
# run under `aspc interpret`, which JITs in-process: it would take the
# compiler down with it.
fn sys_exit_group(i32 code) -> u0 {
    syscall1(SYS_EXIT_GROUP, code)
}

