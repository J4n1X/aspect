{
  "name": "tjlb",
  "displayName": "TJLB Language Support",
  "description": "Syntax highlighting for the TJLB programming language",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "tjlb",
        "aliases": ["TJLB", "tjlb"],
        "extensions": [".tjlb"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tjlb",
        "scopeName": "source.tjlb",
        "path": "./syntaxes/tjlb.tmLanguage.json"
      }
    ]
  }
}
