# expected: 42
# Method chain on an rvalue (function-return) receiver. The receiver — itself
# an sret return — must be materialised into a temporary slot before its
# address can be taken for the next method's `this` parameter.
type Pair {
    public i32 a
    public i32 b
    public fn make(i32 x, i32 y) -> Pair { return Pair { a = x, b = y } }
    public const fn sum(this) -> i32 { return this.a + this.b }
}
fn main(u32 argc, u8 **argv) -> i32 {
    return Pair.make(30, 12).sum()
}
