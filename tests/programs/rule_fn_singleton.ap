# expected: 5
# compile_args: "-I", "lib"
#-
  An Aspect-authored `rule fn` singleton, JIT-compiled and run over the program
  via the std/meta handle ABI. Beyond counting struct literals, it discovers the
  `*$new` factory among the anchor's methods and counts *that constructor's*
  call sites — catching construction funneled through a factory, which
  `instantiations_of` alone cannot see. Config is constructed once, so the rule
  passes and main runs.
-#

rule fn only_one(Program p, Type anchor) -> Judgments {
    Judgments js = Judgments.new()

    # Direct construction sites (struct literals / value allocs).
    ExprList sites = p.instantiations_of(anchor.struct_name())
    if sites.count() > 1 as u64 {
        js.error(sites.at(1 as u64).pos(), "constructed more than once")
    }

    # Construction funneled through a `new` factory: count the constructor's calls.
    FnList methods = anchor.struct_methods()
    for (u64 i = 0; i < methods.count(); i += 1) {
        Fn m = methods.at(i)
        if str_ends_with(m.name(), "$new") {
            ExprList calls = p.call_sites_of(m.name())
            if calls.count() > 1 as u64 {
                js.error(calls.at(1 as u64).pos(), "constructed more than once")
            }
        }
    }

    return js
}

type Config {
    public i32 x
    public fn new(i32 v) -> Config { return Config { x = v } }
}
rule Config only_one

fn main(u32 argc, u8 **argv) -> i32 {
    Config c = Config.new(5)
    return c.x
}
