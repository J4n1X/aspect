# expected: 5
# compile_args: "-I", "lib"
#-
  A bombproof singleton, JIT-compiled and run over the program via the std/meta
  handle ABI. Rather than counting construction sites (which any helper, factory,
  loop, or recursion can defeat), it *confines* construction: the only legal
  place to build the type is a global initializer, which is constant-folded and
  so exists exactly once. Config is a single global built once here, so the rule
  passes and main runs.
-#

rule fn only_one(Program p, Type anchor) -> Judgments {
    Judgments js = Judgments.new()
    u8* name = anchor.struct_name()

    # Forbid any local construction. 
    ExprList in_funcs = p.local_instantiations_of(name)
    if in_funcs.count() > 0 as u64 {
        js.error(in_funcs.at(0 as u64).pos(), "a singleton may be constructed only in a global initializer, not inside a function")
    }

    # And at most one construction total — hence at most one instance.
    ExprList all = p.instantiations_of(name)
    if all.count() > 1 as u64 {
        js.error(all.at(1 as u64).pos(), "a singleton must be constructed at most once")
    }

    return js
}

type Config { public i32 x }
Config g_config = Config { x = 5 }
rule Config only_one

fn main(u32 argc, u8 **argv) -> i32 {
    return g_config.x
}
