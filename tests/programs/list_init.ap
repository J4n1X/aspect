# expected: 42
# Test list initializers: constant, runtime, and global paths.
# Expected exit code: 42

# Global array initialized with a constant list
i32[5] global_arr = {10, 20, 30, 40, 50}

fn sum_global() -> i32 {
    i32 total = 0
    i32 i = 0
    while i < 5 {
        total = total + global_arr[i]
        i = i + 1
    }
    return total  # 10+20+30+40+50 = 150
}

fn sum_local_const() -> i32 {
    # All-literal initializer -- ConstantArray path
    i32[4] arr = {3, 7, 11, 21}
    return arr[0] + arr[1] + arr[2] + arr[3]  # 42
}

fn sum_local_runtime(i32 x) -> i32 {
    # Runtime variable in initializer -- GEP path
    i32[3] arr = {x, x, x}
    return arr[0] + arr[1] + arr[2]  # 3 * x
}

fn main(u32 argc, u8 **argv) -> i32 {
    i32 a = sum_local_const()    # 42
    i32 b = sum_local_runtime(1) # 3
    i32 c = sum_global()         # 150

    # a=42 + b=3 + c=150 = 195; but we return a directly to keep the exit code simple
    # Verify all three work by checking they produce the expected values
    if a != 42 { return 1 }
    if b != 3  { return 2 }
    if c != 150 { return 3 }
    return 42
}
