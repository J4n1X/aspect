# expected: 42
# Parenthesised types — `(T)` is a grouping marker that stops the lexer's
# greedy `T[N]` / `T*` folding so postfix modifiers attach to the *grouped*
# type. Three previously-unspellable shapes exercised here:
#   - array of pointers: `(i32*)[3]`
#   - pointer to fn-ptr: `(fn(...) -> R)*`
#   - global array of fn-ptrs: `(fn(...) -> R)[N]` at file scope
fn id(i32 x) -> i32 { return x }
(fn(i32) -> i32)[1] global_id_table = {&id}

fn main(u32 argc, u8 **argv) -> i32 {
    # Array of i32-pointers.
    i32 a = 5
    i32 b = 12
    i32 c = 20
    (i32*)[3] ptrs = {&a, &b, &c}
    i32 s1 = *ptrs[0] + *ptrs[1] + *ptrs[2]    # 5 + 12 + 20 = 37

    # Pointer to a function pointer, dereferenced for a call.
    fn(i32) -> i32 local = &id
    (fn(i32) -> i32)* pp = &local
    i32 s2 = (*pp)(5)                          # 5

    # Global fn-ptr array.
    i32 s3 = global_id_table[0](0)             # 0

    return s1 + s2 + s3                        # 37 + 5 + 0 = 42
}
