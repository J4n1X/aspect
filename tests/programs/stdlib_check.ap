# expected: 0
# compile_args: "-I", "lib"
#-
  stdlib_check.ap — regression coverage for the standard library
  (lib/std/**). Demos are showcase programs and are NOT part of the test
  suite; the library they share is, via this file. Returns the number of
  failed checks (0 = all good).
-#
$import std/math
$import std/rand
$import std/sort
$import std/collections
$import std/io
$import std/mem
$import std/mem/page
$import std/c/stdlib    # malloc/free used directly below
$import std/c/string    # strcmp used directly below

fn check(bool ok, u8* label) -> i32 {
    if ok {
        print("[PASS] ")
        println(label)
        return 0
    }
    print("[FAIL] ")
    println(label)
    return 1
}

# std/mem/page exists only where a platform file implements it. Windows is
# left out of the checks rather than unimplemented: this suite has never run
# on a Windows host, so gating it in would assert what nobody executes.
$if defined(OS_LINUX) || defined(OS_MACOS)

fn check_pages() -> i32 {
    i32 fails = 0
    u64 psz = page_size()
    # Not `== 4096`: macOS/arm64 pages are 16 KiB. A power of two no smaller
    # than 4 KiB is what every target this runs on guarantees.
    fails += check(psz >= 4096 && (psz & (psz - 1)) == 0, "page_size is a power of two >= 4096")
    fails += check(page_granularity() >= psz, "page_granularity >= page_size")

    # map -> write the whole range -> read back -> release
    u64 n = psz * 4
    u8* p = page_map(n)
    fails += check(p != null, "page_map")
    if p != null {
        u64 i = 0
        while i < n { p[i] = ((i % 251) + 1) as u8 i = i + 1 }
        bool pattern_ok = true
        i = 0
        while i < n {
            if p[i] != ((i % 251) + 1) as u8 { pattern_ok = false }
            i = i + 1
        }
        fails += check(pattern_ok, "page_map range is readable+writable")
        fails += check(page_release(p, n), "page_release")
    }

    # reserve wide, commit narrow, then grow into the reservation
    u64 res = psz * 16
    u8* base = page_reserve(res)
    fails += check(base != null, "page_reserve")
    if base != null {
        fails += check(page_commit(base, psz * 2), "page_commit")
        base[0] = 99
        base[psz * 2 - 1] = 98
        fails += check(page_commit(base, psz * 4), "page_commit grow")
        fails += check(base[0] == 99, "reservation base does not move on grow")
        fails += check(page_decommit(base, psz * 4), "page_decommit")
        fails += check(page_commit(base, psz * 4), "page_commit after decommit")
        # decommit must drop the backing, not merely revoke access — a
        # mprotect-only implementation leaves the old 99 here.
        fails += check(base[0] == 0, "page_decommit drops backing")
        fails += check(page_release(base, res), "page_release reservation")
    }

    # a reservation that cannot fit in the address space fails as null
    u64 huge = 0
    huge = ~huge
    huge = huge / 2
    fails += check(page_reserve(huge) == null, "page_reserve too large -> null")
    fails += check(page_map(huge) == null, "page_map too large -> null")
    return fails
}

$else

fn check_pages() -> i32 { return 0 }

$endif

fn main(u32 argc, u8** argv) -> i32 {
    i32 fails = 0

    # ── math ────────────────────────────────────────────────────────────
    fails += check(min_i64(0 - 3, 5) == 0 - 3, "min_i64")
    fails += check(max_u64(3, 5) == 5, "max_u64")
    fails += check(clamp_i64(42, 0, 10) == 10, "clamp_i64")
    fails += check(abs_i64(0 - 9) == 9, "abs_i64")
    fails += check(gcd_u64(48, 36) == 12, "gcd_u64")
    fails += check(lcm_u64(4, 6) == 12, "lcm_u64")
    fails += check(ipow_u64(3, 7) == 2187, "ipow_u64")
    fails += check(ipow_i64(0 - 2, 5) == 0 - 32, "ipow_i64")
    fails += check(isqrt_u64(144) == 12, "isqrt_u64 exact")
    fails += check(isqrt_u64(145) == 12, "isqrt_u64 floor")
    fails += check(isqrt_u64(0) == 0, "isqrt_u64 zero")
    fails += check(fabs(sqrt_f64(2.0) - 1.41421356237) < 0.0000001, "sqrt_f64")
    fails += check(sqrt_f64(0.0) == 0.0, "sqrt_f64 zero")
    fails += check(floor_f64(2.7) == 2.0, "floor_f64")
    fails += check(floor_f64(0.0 - 2.7) == 0.0 - 3.0, "floor_f64 neg")
    fails += check(ceil_f64(2.1) == 3.0, "ceil_f64")
    fails += check(round_f64(2.5) == 3.0, "round_f64")
    fails += check(round_f64(0.0 - 2.5) == 0.0 - 3.0, "round_f64 neg")

    # ── rand ────────────────────────────────────────────────────────────
    Rng r1 = Rng.seeded(42)
    Rng r2 = Rng.seeded(42)
    fails += check(r1.next_u64() == r2.next_u64(), "rng deterministic")
    Rng r3 = Rng.seeded(7)
    bool in_range = true
    for (i32 i = 0; i < 1000; i += 1) {
        u64 v = r3.below(6)
        if v >= 6 { in_range = false }
    }
    fails += check(in_range, "rng below bound")
    bool unit_ok = true
    for (i32 i = 0; i < 1000; i += 1) {
        f64 u = r3.next_f64()
        if u < 0.0 || u >= 1.0 { unit_ok = false }
    }
    fails += check(unit_ok, "rng next_f64 unit interval")
    bool spread = false
    for (i32 i = 0; i < 100; i += 1) {
        i64 v = r3.range_i64(0 - 10, 10)
        if v < 0 { spread = true }
        if v < 0 - 10 || v >= 10 { spread = false break }
    }
    fails += check(spread, "rng range_i64")

    # ── sort ────────────────────────────────────────────────────────────
    i32[9] xs = {5, 2, 9, 1, 7, 3, 8, 4, 6}
    sort_i32(xs, 9)
    bool sorted = true
    for (i32 i = 0; i < 8; i += 1) {
        if xs[i] > xs[i + 1] { sorted = false }
    }
    fails += check(sorted, "sort_i32 small")

    # large array through the quicksort path (reverse order, 200 elems)
    i64* big = malloc(200 * sizeof(i64))
    for (i64 i = 0; i < 200; i += 1) {
        big[i] = 200 - i
    }
    sort_i64(big, 200)
    bool big_ok = true
    for (i64 i = 0; i < 200; i += 1) {
        if big[i] != i + 1 { big_ok = false }
    }
    free(big)
    fails += check(big_ok, "sort_i64 large (quicksort path)")

    (u8*)[4] names = {"cherry", "apple", "durian", "banana"}
    sort_cstr(names, 4)
    bool names_ok = strcmp(names[0], "apple") == 0 && strcmp(names[3], "durian") == 0
    fails += check(names_ok, "sort_cstr")

    i32[5] desc = {1, 5, 3, 2, 4}
    sort_bytes(desc, 5, sizeof(i32), &cmp_i32_desc)
    fails += check(desc[0] == 5 && desc[4] == 1, "sort_bytes desc comparator")

    # ── map ─────────────────────────────────────────────────────────────
    MapStrI64 m = MapStrI64.new()
    m.put("apple", 3)
    m.put("banana", 5)
    m.put("apple", 4)                       # overwrite
    fails += check(m.get_or("apple", 0) == 4, "map overwrite")
    fails += check(m.get_or("banana", 0) == 5, "map get")
    fails += check(m.get_or("pear", 0 - 1) == 0 - 1, "map fallback")
    fails += check(m.contains("banana"), "map contains")
    fails += check(!m.contains("pear"), "map not contains")
    fails += check(m.len() == 2, "map len")

    # force several growths: 100 distinct keys
    u8[16] keybuf
    for (i32 i = 0; i < 100; i += 1) {
        keybuf[0] = (107) as u8              # 'k'
        keybuf[1] = (48 + i / 100 % 10) as u8
        keybuf[2] = (48 + i / 10 % 10) as u8
        keybuf[3] = (48 + i % 10) as u8
        keybuf[4] = 0
        m.put(keybuf, i as i64)
    }
    fails += check(m.len() == 102, "map len after growth")
    keybuf[0] = 107 as u8
    keybuf[1] = 48 as u8
    keybuf[2] = 52 as u8                     # '4'
    keybuf[3] = 50 as u8                     # '2'
    keybuf[4] = 0
    fails += check(m.get_or(keybuf, 0 - 1) == 42, "map get after growth")
    fails += check(m.get_or("apple", 0) == 4, "map old key after growth")
    m.destroy()

    # ── std/mem ─────────────────────────────────────────────────────────
    u8* raw = alloc_bytes(64)
    fails += check(raw != null, "alloc_bytes")
    if raw != null {
        raw[0] = 7
        raw[63] = 9
        fails += check(raw[0] == 7 && raw[63] == 9, "alloc_bytes is writable")
        free_ptr(raw)
    }
    u8* zeroed = zalloc_bytes(64)
    fails += check(zeroed != null, "zalloc_bytes")
    if zeroed != null {
        bool all_zero = true
        for (i32 i = 0; i < 64; i += 1) {
            if zeroed[i] != 0 { all_zero = false }
        }
        fails += check(all_zero, "zalloc_bytes is zeroed")
        free_ptr(zeroed)
    }
    fails += check_pages()

    if fails == 0 {
        println("ALL STDLIB CHECKS PASSED")
    } else {
        print("FAILURES: ")
        println_i32(fails)
    }
    return fails
}
