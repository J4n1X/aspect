# expected: 25
# Regression: `continue` inside a `for` loop must jump to the increment
# step, not directly back to the condition. If it skipped the increment,
# the first `continue` would freeze the loop variable at its current
# value and the program would never terminate. Sums odd values 1..=10:
# 1 + 3 + 5 + 7 + 9 = 25.
fn main(u32 argc, u8 **argv) -> i32 {
    i32 sum = 0
    for (i32 i = 1; i <= 10; i = i + 1) {
        if i % 2 == 0 { continue }
        sum = sum + i
    }
    return sum
}
