# expected: 0
# compile_args: "-D", "STD_NO_LIBC", "-I", "lib"
# requires_arch: ARCH_X86_64
#-
  alloc_basic.ap — the freestanding allocator (`std/mem` under STD_NO_LIBC):
  the everyday path. Basic alloc -> write -> read -> free, free-then-alloc
  reuse of the same block, 16-byte alignment of every result, and a batch of
  many small allocations written and read back. Exit code is the failed-check
  count, so `# expected: 0` = all good. Runs at -O0 and -O2 (must agree).
-#
$import std/mem

fn fail_if(bool bad) -> i32 {
    if bad { return 1 }
    return 0
}

fn main(u32 argc, u8** argv) -> i32 {
    i32 fails = 0

    # ── alloc -> write -> read -> free ──────────────────────────────────
    u8* a = malloc(64)
    fails += fail_if(a == null)
    if a != null {
        for (u64 i = 0; i < 64; i += 1) {
            a[i] = ((i * 7) % 251) as u8
        }
        bool ok = true
        for (u64 i = 0; i < 64; i += 1) {
            if a[i] != ((i * 7) % 251) as u8 { ok = false }
        }
        fails += fail_if(!ok)
        free(a)
    }

    # ── free then alloc: the freed block is reused (first fit) ───────────
    u8* p1 = malloc(48)
    u64 addr1 = p1 as u64
    free(p1)
    u8* p2 = malloc(48)
    u64 addr2 = p2 as u64
    fails += fail_if(addr1 != addr2)          # same slot came back
    free(p2)

    # ── malloc's 16-byte alignment guarantee, across sizes ──────────────
    u64[8] szs = {1, 7, 16, 17, 100, 255, 1024, 4095}
    for (u64 i = 0; i < 8; i += 1) {
        u8* q = malloc(szs[i])
        fails += fail_if(q == null)
        fails += fail_if(((q as u64) & 15) != 0)   # 16-aligned
        if q != null {
            q[0] = 1
            free(q)
        }
    }

    # ── many small allocations, all live at once, each written+read ─────
    (u8*)[200] ps
    bool small_ok = true
    for (u64 i = 0; i < 200; i += 1) {
        u8* r = malloc(24)
        if r == null { small_ok = false }
        ps[i] = r
        if r != null { r[0] = (i % 256) as u8  r[23] = ((i * 3) % 256) as u8 }
    }
    for (u64 i = 0; i < 200; i += 1) {
        u8* r = ps[i]
        if r == null { small_ok = false }
        if r != null {
            if r[0] != (i % 256) as u8 { small_ok = false }
            if r[23] != ((i * 3) % 256) as u8 { small_ok = false }
        }
    }
    for (u64 i = 0; i < 200; i += 1) {
        free(ps[i])
    }
    fails += fail_if(!small_ok)

    # ── libc-compatible edge cases: free(null) is a no-op; malloc(0)
    #    returns a unique, freeable pointer ──────────────────────────────
    free(null)
    u8* z = malloc(0)
    fails += fail_if(z == null)
    free(z)

    return fails
}
