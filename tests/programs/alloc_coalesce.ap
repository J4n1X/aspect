# expected: 0
# compile_args: "-D", "STD_NO_LIBC", "-I", "lib"
# requires_arch: ARCH_X86_64
#-
  alloc_coalesce.ap — boundary-tag coalescing in the freestanding allocator.
  Two physically adjacent blocks are freed and the merged space then satisfies
  a request larger than either block alone — only coalescing can serve it from
  that spot. The merged block reuses the lower block's address, which is the
  observable proof the tags joined the neighbours rather than leaving two
  fragments. Exit code is the failed-check count (`# expected: 0`).
-#
$import std/mem

fn fail_if(bool bad) -> i32 {
    if bad { return 1 }
    return 0
}

fn main(u32 argc, u8** argv) -> i32 {
    i32 fails = 0

    # Two consecutive small allocations off a fresh heap are physically
    # adjacent: `b` sits right after `a`.
    u8* a = malloc(64)
    u8* b = malloc(64)
    u8* guard = malloc(64)        # keeps the region from ending right after b
    fails += fail_if(a == null || b == null || guard == null)
    u64 addr_a = a as u64
    fails += fail_if((b as u64) <= addr_a)      # b is above a
    fails += fail_if((b as u64) - addr_a != 80) # 64 payload rounds to a 80-byte block

    # Freeing both leaves one merged free block starting at a's header.
    free(a)
    free(b)

    # A request bigger than a single 64-byte block, but within the merged
    # 160 bytes, must be served from the coalesced span at a's address.
    u8* big = malloc(120)
    fails += fail_if(big == null)
    fails += fail_if((big as u64) != addr_a)    # reused the merged slot

    # And it is fully usable across the former boundary.
    if big != null {
        for (u64 i = 0; i < 120; i += 1) {
            big[i] = ((i * 5 + 1) % 251) as u8
        }
        bool ok = true
        for (u64 i = 0; i < 120; i += 1) {
            if big[i] != ((i * 5 + 1) % 251) as u8 { ok = false }
        }
        fails += fail_if(!ok)
        free(big)
    }
    free(guard)

    # Backward coalescing: free low, then high; freeing high must merge into
    # the already-free low neighbour (via its footer), again yielding a's slot.
    u8* c = malloc(64)
    u8* d = malloc(64)
    u8* guard2 = malloc(64)
    u64 addr_c = c as u64
    free(c)                        # low goes free first
    free(d)                        # high merges backward into low
    u8* merged = malloc(120)
    fails += fail_if((merged as u64) != addr_c)
    free(merged)
    free(guard2)

    return fails
}
