# expected: 13
# compile_args: "-I", "lib", "-I", "tests/modules"
#-
  A complex module split exercising the JIT meta engine under module scoping.
  `mcfg` defines Config; `msvca` and `msvcb` each construct it inside a function
  (and both import `mcfg`, so it's a diamond, loaded once). This entry declares a
  single legitimate Config as a global, and a *private* bombproof-singleton rule
  fn — which, being module-scoped, judges only this entry file: it sees the one
  global construction (a run-once initializer) and passes, ignoring msvca/msvcb's
  in-function constructions. main returns 1 + 5 + 7 = 13.
-#
$import mcfg
$import msvca
$import msvcb

Config g_config = Config { x = 1 }

rule fn only_one(Program p, Type anchor) -> Judgments {
    Judgments js = Judgments.new()
    u8* name = anchor.struct_name()

    ExprList in_funcs = p.local_instantiations_of(name)
    if in_funcs.count() > 0 as u64 {
        js.error(in_funcs.at(0 as u64).pos(), "a singleton may be constructed only in a global initializer, not inside a function")
    }

    ExprList all = p.instantiations_of(name)
    if all.count() > 1 as u64 {
        js.error(all.at(1 as u64).pos(), "a singleton must be constructed at most once")
    }

    return js
}
rule Config only_one

fn main(u32 argc, u8 **argv) -> i32 {
    return g_config.x + a_val() + b_val()
}
