# expected: 42
#-
  void_pointers.tjlb — regression test for `u0*` (the opaque pointer type).

  Legal:
    * `u0*` variables, params, returns, fields-of-pointer-kind
    * implicit same-depth coercion in BOTH directions (T* <-> u0*),
      matching the language's existing permissive pointer model
    * comparisons and null tests (`p == null`, `!p`, truthiness)
    * `u0**` (pointee is a sized pointer) including subscripts
    * sizeof(u0*)

  Illegal (see failures/void_*.tjlb):
    * `u0` as a value type (variables, params, globals)
    * dereference / subscript of `u0*`
    * pointer arithmetic on `u0*`
-#

extern fn malloc(u64 size) -> u0*
extern fn free(u0* p) -> u0

type Node {
    public i64 tag
    public u0* payload      # opaque payload — cast at the use site
}

fn erase(u0* p) -> u0* {
    return p
}

fn main(u32 argc, u8** argv) -> i32 {
    i32 score = 0

    # null handling + logical not
    u0* nothing = null
    if nothing == null { score += 1 }               # 1
    if !nothing { score += 1 }                      # 2

    # round trip: i64* -> u0* (implicit) -> i64* (cast)
    i64* xs = malloc(2 * sizeof(i64)) as i64*
    xs[0] = 20
    u0* opaque = erase(xs)
    if opaque != null { score += 1 }                # 3
    i64* back = opaque as i64*
    back[1] = back[0] + 1
    if xs[1] == 21 { score += 1 }                   # 4

    # opaque payload field on a struct
    Node n = Node { tag = 7, payload = xs }
    i64* payload = n.payload as i64*
    if payload[0] == 20 { score += 1 }              # 5
    if n.tag == 7 { score += 1 }                    # 6

    # u0** — pointee is sized, so subscripting is fine
    u0** table = malloc(2 * sizeof(u0*)) as u0**
    table[0] = opaque
    table[1] = null
    if table[0] == opaque { score += 1 }            # 7
    if table[1] == null { score += 1 }              # 8

    # sizeof
    if sizeof(u0*) == sizeof(u8*) { score += 1 }    # 9

    free(xs)                                        # i64* -> u0* implicit
    free(table as u0*)
    if score == 9 { return 42 }
    return score
}
