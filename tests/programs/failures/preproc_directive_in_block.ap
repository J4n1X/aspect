# expected: "top level", "inside a block"
# Conditional directives (`$if*`/`$else`/`$endif`) are allowed inside a
# function body, but the state-mutating directives are not: a line-leading
# `$define`/`$undefine`/`$module`/`$import` at brace depth > 0 is an error.

fn main(u32 argc, u8 **argv) -> i32 {
$define ENABLED 1
    return ENABLED
}
