# Intermediary of the visibility chain: imports `hidden` directly, so its
# code may use every `hidden` symbol; importers of `middle` may call into
# `middle` but must not reach `hidden` themselves.
$module middle
$import hidden

fn middle_value() -> i32 {
    HiddenBox b = HiddenBox.make(hidden_global)     # type + static method + global
    HiddenInt bonus = 1                             # alias
    return b.get() + hidden_value() + (bonus as i32) # instance method + function
}
